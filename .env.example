# Supabase PostgreSQL (Session pooler, port 5432)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Production URL
NEXTAUTH_URL="https://dovezu.vercel.app"
NEXTAUTH_SECRET="generate-random-string-min-32-chars"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_DEFAULT_CHAT_ID="your-chat-id"

# Web Push (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
